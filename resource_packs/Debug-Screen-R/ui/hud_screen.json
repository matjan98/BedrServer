    "title_data": {
        "$update_string": "!",
        "type": "panel",
        "size": [0, 0],
        "bindings": [
            {
                "binding_name": "#hud_title_text_string"
            },
            {
                "binding_name": "#hud_title_text_string",
                "binding_name_override": "#preserved_text",
                "binding_condition": "visibility_changed"
            },
            {
                "binding_type": "view",
                "source_property_name": "(not (#hud_title_text_string = #preserved_text) and (('%.1s' * #hud_title_text_string) = $update_string)",
                "target_property_name": "#visible"
            }
        ]
    },
    
    "field_text": {
        "type": "label",
        "text": "#text",
        "shadow": true,
        "controls": [
            {
                "title_data@hud.title_data": {}
            }
        ],
        "bindings": [
            {
                "binding_type": "view",
                "source_control_name": "title_data",
                "source_property_name": "(((('%.' + ($field_no * 100) + 's') * #preserved_text) - (('%.' + (($field_no - 1) * 100) + 's') * #preserved_text)) - '!')",
                "target_property_name": "#text"
            }
        ]
    },

    "field_base": {
        "$field_no": 1,
        "type": "image",
        "texture": "textures/ui/Black",
        "alpha": 0.2,
        "size": ["101%c", "101%c"],
        "controls": [
            {
                "field_text@hud.field_text": {}
            }
        ]
    },

    "field_base_right@hud.field_base": {
        "anchor_from": "top_right",
        "anchor_to": "top_right"
    },

    "field_base_left@hud.field_base": {
        "anchor_from": "top_left",
        "anchor_to": "top_left"
    },
    
    "debug_touch_toggle@common_buttons.light_text_button": {
        "focus_enabled": false,
        "prevent_touch_input": true,
        "$pressed_button_name": "button.hide_paperdoll_hud",
        "size": [18, 18],
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "offset": [38, 1],
        "controls": [
            {
                "touch_icon": {
                    "type": "image",
                    "texture": "textures/debug/debug_button"
                }
            }
        ],
        "bindings": [
            {
                "binding_name": "#inventory_touch_button",
                "binding_name_override": "#visible",
                "binding_type": "global"
            }
        ]
    },
    
    "hud_title_text/title_frame/title": {
        "modifications": [
            {
                "array_name": "bindings",
                "operation": "insert_back",
                "value": {
                    "binding_type": "view",
                    "source_property_name": "(not (#text = #text))",
                    "target_property_name": "#visible"
                }
            }
        ]
    },
    
    "root_panel": {
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_front",
                "value": [
                    {
                        "left_debug_panel@hud.left_debug_panel": {}
                    },
                    {
                        "right_debug_panel@hud.right_debug_panel": {}
                    },
                    {
                        "debug_touch_toggle@hud.debug_touch_toggle": {}
                    }
                ]
            }
        ]
    }
}